# Copy this file to backend/.env and fill in the values you have access to.
# .env is gitignored; .env.example is the committed template.

# ─── Scopus / Elsevier ──────────────────────────────────────────────
# Get an API key at https://dev.elsevier.com/. The institutional token
# (X-ELS-Insttoken) is only needed if your access is institution-bound.
SCOPUS_API_KEY=
SCOPUS_INST_TOKEN=

# ─── Dimensions (Digital Science) ───────────────────────────────────
# Either a long-lived API key, or username + password.
# Auth endpoint: https://app.dimensions.ai/api/auth
DIMENSIONS_API_KEY=
DIMENSIONS_USERNAME=
DIMENSIONS_PASSWORD=

# ─── OpenAlex politeness pool ───────────────────────────────────────
OPENALEX_MAILTO=

# ─── Paths ──────────────────────────────────────────────────────────
# Where per-author enrichment JSON gets cached so re-runs don't re-hit
# the upstream APIs. Defaults to backend/data/cache.
ENRICHMENT_CACHE_DIR=
